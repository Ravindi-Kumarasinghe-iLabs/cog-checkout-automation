{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["features/**/*.ts", "steps/**/*.ts", "pages/**/*.ts", "support/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist", "reports"]
}
